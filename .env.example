# Google Calendar API Credentials
# Get these from https://console.cloud.google.com -> Credentials -> OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Stripe Keys (Optional for local testing if you bypass payments)
STRIPE_SECRET_KEY=sk_test_...

# Database Config (Matches docker-compose.yml defaults)
POSTGRES_USER=lfc_user
POSTGRES_PASSWORD=lfc_pass
POSTGRES_DB=lfc_monitor
DATABASE_URL=postgresql+asyncpg://lfc_user:lfc_pass@db:5432/lfc_monitor

# Frontend Config
VITE_API_URL=http://localhost:8000
